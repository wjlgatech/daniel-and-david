# KC Matchday Basecamp — environment template.
# Copy to .env.local and fill in real values. NEVER commit the real .env file.
# Secret keys go in server-only env (no NEXT_PUBLIC_ prefix).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only — never expose to the client

# --- Stripe ---
STRIPE_SECRET_KEY=                # server-only — never expose to the client
STRIPE_WEBHOOK_SECRET=            # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=                   # server-only
EMAIL_FROM=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPS_BASE_URL=https://www.google.com/maps/search/?api=1&query=

# --- Local development ---
# Set to "true" to use mock payments instead of live Stripe (see SPEC §6.9).
NEXT_PUBLIC_MOCK_PAYMENTS=true
