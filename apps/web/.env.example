# Env for the optional, parent-facing free-LLM proxy (api/spark.js / netlify edge function).
# The whole site + every demo works WITHOUT any of these — they're only for the ✨ "fresh ideas"
# enhancement. Set these in your host (Vercel/Netlify env), NOT committed. See DEPLOY.md.

# --- REQUIRED to turn the ✨ button on: a free, OpenAI-compatible LLM key ---
# Get one at https://build.nvidia.com (NVIDIA NIM, free tier).
NIM_API_KEY=nvapi-...

# --- Optional overrides (sensible defaults baked in) ---
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1   # any OpenAI-compatible base
# NIM_MODEL=meta/llama-3.1-70b-instruct
